<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pokédex</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>

<header>
  <h1>Pokédex</h1>
  <input id="buscador" type="text" placeholder="Buscar por nombre..." />
</header>

<nav>
  <button id="btn-todos" class="activo" onclick="mostrarTodos()">Todos</button>
  <button id="btn-favs" onclick="mostrarFavoritos()">⭐ Favoritos</button>
</nav>

<div id="error-msg"></div>
<div id="spinner">Cargando...</div>
<div id="grid"></div>

<div id="paginacion">
  <button id="btn-prev" onclick="cambiarPagina(-1)" disabled>← Anterior</button>
  <span id="pag-info"></span>
  <button id="btn-next" onclick="cambiarPagina(1)">Siguiente →</button>
</div>

<div id="modal-overlay" onclick="cerrarModal(event)">
  <div id="modal">
    <button id="btn-cerrar" onclick="cerrarModal()">✕</button>
    <img id="modal-img" src="" alt="" />
    <h2 id="modal-nombre"></h2>
    <p class="num-modal" id="modal-num"></p>
    <div class="tipos" id="modal-tipos"></div>
    <div class="stats" id="modal-stats"></div>
    <button id="btn-fav" onclick="toggleFavorito()"></button>
  </div>
</div>

<script src="app.js"></script>
</body>
</html>
